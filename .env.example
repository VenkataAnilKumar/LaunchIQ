# ─────────────────────────────────────────
# LaunchIQ — Environment Variables Template
# Copy to .env.local and fill in values
# NEVER commit real values to git
# ─────────────────────────────────────────

# Core AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_OPUS=claude-opus-4-6
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# Database (Supabase)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@localhost:5432/launchiq

# Vector Store (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Cache + Queue (Redis)
REDIS_URL=redis://localhost:6379/0

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWT_AUDIENCE=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=
# Generate with: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=replace-with-strong-random-secret

# MCP Tools
TAVILY_API_KEY=tvly-...
HUBSPOT_API_KEY=
SLACK_BOT_TOKEN=xoxb-...
GA4_PROPERTY_ID=

# Observability
LANGSMITH_API_KEY=ls_...
LANGSMITH_PROJECT=launchiq-dev
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Infrastructure (AWS)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Logging
# Options: debug | info | warning | error
LOG_LEVEL=info
